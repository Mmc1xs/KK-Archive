{
  "name": "kk-diction",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "prisma generate && next build",
    "build:postgres": "npm run db:use:postgres && prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "guard:image-cost": "node scripts/check-image-cost-guardrails.mjs",
    "db:use:sqlite": "tsx scripts/set-prisma-runtime.ts sqlite",
    "db:use:postgres": "tsx scripts/set-prisma-runtime.ts postgres",
    "db:generate": "prisma generate",
    "db:generate:postgres": "prisma generate --schema prisma/schema.postgres.prisma",
    "db:generate:migrate:sqlite": "prisma generate --schema prisma/schema.migrate.sqlite.prisma",
    "db:generate:migrate:postgres": "prisma generate --schema prisma/schema.migrate.postgres.prisma",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:push:postgres": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:harden:supabase": "prisma db execute --schema prisma/schema.postgres.prisma --file scripts/harden-supabase-public.sql",
    "db:indexes:performance": "prisma db execute --schema prisma/schema.postgres.prisma --file scripts/add-performance-indexes.sql",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate:sqlite-to-postgres": "npm run db:generate:migrate:sqlite && npm run db:generate:migrate:postgres && tsx scripts/migrate-sqlite-to-postgres.ts",
    "db:backfill-usernames": "tsx scripts/backfill-usernames.ts",
    "db:backfill-source-links": "tsx scripts/backfill-content-source-links.ts",
    "clean:manifest": "tsx scripts/build-clean-import-manifest.ts",
    "clean:pixiv": "tsx scripts/enrich-clean-from-pixiv.ts",
    "clean:pixiv:new": "tsx scripts/enrich-new-clean-from-pixiv.ts",
    "clean:post-json": "tsx scripts/write-post-json-from-clean.ts",
    "clean:post-json:new": "tsx scripts/write-new-post-json-from-clean.ts",
    "clean:import-one": "tsx scripts/import-clean-post.ts",
    "clean:import-all": "tsx scripts/import-all-clean-posts.ts",
    "clean:import-new": "tsx scripts/import-new-clean-posts.ts",
    "clean:sync-new": "tsx scripts/sync-new-clean-content.ts",
    "clean:sync-all": "tsx scripts/sync-all-clean-content.ts",
    "cut:import:queue": "tsx scripts/import-cut-queue.ts",
    "cut:import:queue:file": "tsx scripts/import-cut-queue.ts",
    "clean:move-unuploaded:later": "tsx scripts/move-unuploaded-clean-to-later.ts",
    "clean:move-unuploaded:later:apply": "tsx scripts/move-unuploaded-clean-to-later.ts --apply",
    "tag:export-review": "tsx scripts/export-tag-review-json.ts",
    "tag:import-review": "tsx scripts/import-tag-review-json.ts",
    "clean:work-report": "tsx scripts/report-pixiv-work-candidates.ts",
    "clean:work-apply": "tsx scripts/apply-pixiv-work-tags.ts",
    "clean:work-report:blue-archive": "tsx scripts/report-blue-archive-work-candidates.ts",
    "clean:work-apply:blue-archive": "tsx scripts/apply-blue-archive-work-tags.ts",
    "sync:new": "npm run clean:sync-new",
    "sync:all": "npm run clean:sync-all",
    "r2:upload-clean": "tsx scripts/upload-clean-to-r2.ts",
    "r2:upload-clean:new": "tsx scripts/upload-new-clean-to-r2.ts",
    "content:replace-images": "tsx scripts/replace-content-images.ts",
    "codex:handoff": "tsx scripts/generate-codex-handoff.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@aws-sdk/lib-storage": "^3.1012.0",
    "@aws-sdk/s3-request-presigner": "^3.1012.0",
    "@prisma/client": "^6.5.0",
    "next": "^16.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.2"
  }
}
