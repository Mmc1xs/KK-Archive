generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AUDIT
  MEMBER
}

enum ReviewStatus {
  UNVERIFIED
  EDITED
  PASSED
}

enum PublishStatus {
  DRAFT
  SUMMIT
  PUBLISHED
  COMPLIANCE_REJECTED
  INVISIBLE
}

enum TagType {
  AUTHOR
  WORK
  CHARACTER
  STYLE
  USAGE
  TYPE
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  username            String?   @unique @map("username")
  usernameUpdatedAt   DateTime? @map("username_updated_at")
  passwordHash        String?   @map("password_hash")
  googleId            String?   @unique @map("google_id")
  googleEmailVerified Boolean   @default(false) @map("google_email_verified")
  lastLoginAt         DateTime? @map("last_login_at")
  lastSeenAt          DateTime? @map("last_seen_at")
  loginCount          Int       @default(0) @map("login_count")
  isSuspended         Boolean   @default(false) @map("is_suspended")
  suspendedAt         DateTime? @map("suspended_at")
  settlementQuantity  Int       @default(0) @map("settlement_quantity")
  role                UserRole  @default(MEMBER)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  loginEvents         UserLoginEvent[]
  editedContents      Content[] @relation("ContentEditedBy")
  firstEditedContents Content[] @relation("ContentFirstEditedBy")
  passedContents      Content[] @relation("ContentPassedBy")
  contentIssueReports ContentIssueReport[]
  contentDownloadEvents ContentDownloadEvent[]
  staffUploads        StaffUpload[] @relation("StaffUploadUploader")
  uploadedHostedFiles ContentFile[] @relation("ContentFileUploadedBy")
  ignoredSiteDownloadDemos ContentSiteDownloadDemo[] @relation("ContentSiteDownloadDemoIgnoredBy")
  completedSiteDownloadDemos ContentSiteDownloadDemo[] @relation("ContentSiteDownloadDemoCompletedBy")

  @@map("users")
}

model UserLoginEvent {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  provider  String
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("user_login_events")
}

model Content {
  id            Int                   @id @default(autoincrement())
  title         String
  slug          String                @unique
  description   String
  coverImageUrl String                @map("cover_image_url")
  storageFolder String?               @map("storage_folder")
  sourceLink    String?               @map("source_link")
  isVerified    Boolean               @default(false) @map("is_verified")
  reviewStatus  ReviewStatus          @default(UNVERIFIED) @map("review_status")
  editedByUserId Int?                 @map("edited_by_user_id")
  editedAt      DateTime?             @map("edited_at")
  firstEditedByUserId Int?            @map("first_edited_by_user_id")
  firstEditedAt DateTime?             @map("first_edited_at")
  passedByUserId Int?                 @map("passed_by_user_id")
  passedAt      DateTime?             @map("passed_at")
  memberReportOriginalSourceCount Int @default(0) @map("member_report_original_source_count")
  memberReportWebsiteDownloadCount Int @default(0) @map("member_report_website_download_count")
  viewCount     Int                   @default(0) @map("view_count")
  lastViewedAt  DateTime?             @map("last_viewed_at")
  publishStatus PublishStatus         @default(DRAFT) @map("publish_status")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  editedBy      User?                 @relation("ContentEditedBy", fields: [editedByUserId], references: [id], onDelete: SetNull)
  firstEditedBy User?                 @relation("ContentFirstEditedBy", fields: [firstEditedByUserId], references: [id], onDelete: SetNull)
  passedBy      User?                 @relation("ContentPassedBy", fields: [passedByUserId], references: [id], onDelete: SetNull)
  images        ContentImage[]
  downloadLinks ContentDownloadLink[]
  hostedFiles   ContentFile[]
  staffUploads  StaffUpload[]
  siteDownloadDemo ContentSiteDownloadDemo?
  contentTags   ContentTag[]
  dailyViews    ContentViewDaily[]
  dailyDownloads ContentDownloadDaily[]
  downloadEvents ContentDownloadEvent[]
  issueReports   ContentIssueReport[]
  hotTopicSlots HomepageHotTopicSlot[]

  @@index([publishStatus, createdAt])
  @@index([reviewStatus, updatedAt])
  @@map("contents")
}

model ContentViewDaily {
  contentId Int      @map("content_id")
  viewDate  DateTime @map("view_date")
  viewCount Int      @default(0) @map("view_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@id([contentId, viewDate])
  @@index([viewDate])
  @@index([viewDate, viewCount])
  @@map("content_view_daily")
}

model ContentDownloadDaily {
  contentId     Int      @map("content_id")
  downloadDate  DateTime @map("download_date")
  downloadCount Int      @default(0) @map("download_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  content       Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@id([contentId, downloadDate])
  @@index([downloadDate])
  @@index([downloadDate, downloadCount])
  @@map("content_download_daily")
}

model ContentDownloadAudienceDaily {
  audienceDate       DateTime @id @map("audience_date")
  userDownloadCount  Int      @default(0) @map("user_download_count")
  guestDownloadCount Int      @default(0) @map("guest_download_count")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([audienceDate])
  @@map("content_download_audience_daily")
}

model ContentDownloadEvent {
  id           Int      @id @default(autoincrement())
  contentId    Int      @map("content_id")
  userId       Int?     @map("user_id")
  downloadedAt DateTime @default(now()) @map("downloaded_at")
  content      Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([contentId, downloadedAt])
  @@index([userId, downloadedAt])
  @@index([downloadedAt])
  @@map("content_download_events")
}

model ContentIssueReport {
  id        Int      @id @default(autoincrement())
  contentId Int      @map("content_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@index([contentId, createdAt])
  @@index([userId, createdAt])
  @@map("content_issue_reports")
}

model HomepageHotTopicSlot {
  slot      Int      @id
  contentId Int?     @unique @map("content_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  content   Content? @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@map("homepage_hot_topic_slots")
}

model ContentImage {
  id        Int      @id @default(autoincrement())
  contentId Int      @map("content_id")
  imageUrl  String   @map("image_url")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("content_images")
}

model ContentDownloadLink {
  id        Int      @id @default(autoincrement())
  contentId Int      @map("content_id")
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("content_download_links")
}

enum StaffUploadStatus {
  PENDING
  UPLOADING
  COMPLETED
  FAILED
  ABORTED
}

enum StaffUploadMethod {
  SINGLE
  MULTIPART
}

enum SiteDownloadDemoStatus {
  PENDING
  IGNORED
  UPLOADED
  FAILED
}

model StaffUpload {
  id               Int               @id @default(autoincrement())
  contentId        Int               @map("content_id")
  uploaderId       Int               @map("uploader_id")
  originalFileName String            @map("original_file_name")
  objectKey        String            @map("object_key")
  mimeType         String            @map("mime_type")
  byteSize         Int               @map("byte_size")
  uploadMethod     StaffUploadMethod @map("upload_method")
  status           StaffUploadStatus @default(PENDING)
  r2UploadId       String?           @map("r2_upload_id")
  errorMessage     String?           @map("error_message")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  completedAt      DateTime?         @map("completed_at")
  content          Content           @relation(fields: [contentId], references: [id], onDelete: Cascade)
  uploader         User              @relation("StaffUploadUploader", fields: [uploaderId], references: [id], onDelete: Restrict)
  file             ContentFile?

  @@index([contentId, status])
  @@index([uploaderId, createdAt])
  @@map("staff_uploads")
}

model ContentFile {
  id               Int         @id @default(autoincrement())
  contentId        Int         @map("content_id")
  staffUploadId    Int?        @unique @map("staff_upload_id")
  fileName         String      @map("file_name")
  objectKey        String      @map("object_key")
  mimeType         String      @map("mime_type")
  byteSize         Int         @map("byte_size")
  sortOrder        Int         @default(0) @map("sort_order")
  uploadedByUserId Int         @map("uploaded_by_user_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  content          Content     @relation(fields: [contentId], references: [id], onDelete: Cascade)
  staffUpload      StaffUpload? @relation(fields: [staffUploadId], references: [id], onDelete: SetNull)
  uploadedBy       User        @relation("ContentFileUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Restrict)

  @@index([contentId, sortOrder])
  @@index([uploadedByUserId, createdAt])
  @@map("content_files")
}

model ContentSiteDownloadDemo {
  id                 Int                    @id @default(autoincrement())
  contentId          Int                    @unique @map("content_id")
  status             SiteDownloadDemoStatus @default(PENDING)
  telegramSourceUrl  String?                @map("telegram_source_url")
  resolvedTargetUrls String?                @map("resolved_target_urls")
  selectedFilesJson  String?                @map("selected_files_json")
  errorMessage       String?                @map("error_message")
  ignoredByUserId    Int?                   @map("ignored_by_user_id")
  ignoredAt          DateTime?              @map("ignored_at")
  completedByUserId  Int?                   @map("completed_by_user_id")
  completedAt        DateTime?              @map("completed_at")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  content            Content                @relation(fields: [contentId], references: [id], onDelete: Cascade)
  ignoredBy          User?                  @relation("ContentSiteDownloadDemoIgnoredBy", fields: [ignoredByUserId], references: [id], onDelete: SetNull)
  completedBy        User?                  @relation("ContentSiteDownloadDemoCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
  @@index([ignoredByUserId, updatedAt])
  @@index([completedByUserId, updatedAt])
  @@map("content_site_download_demos")
}

model Tag {
  id          Int          @id @default(autoincrement())
  name        String
  slug        String       @unique
  type        TagType
  workTagId   Int?         @map("work_tag_id")
  workTag     Tag?         @relation("CharacterWork", fields: [workTagId], references: [id], onDelete: Restrict)
  characters  Tag[]        @relation("CharacterWork")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  contentTags ContentTag[]

  @@index([type, workTagId, name])
  @@map("tags")
}

model ContentTag {
  contentId Int     @map("content_id")
  tagId     Int     @map("tag_id")
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
  @@index([tagId, contentId])
  @@map("content_tags")
}
