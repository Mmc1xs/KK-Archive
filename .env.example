DATABASE_URL="file:./prisma/dev.db"
SESSION_SECRET="replace-with-a-long-random-secret"
SITE_URL="http://localhost:3000"
NEXT_PUBLIC_ADSENSE_CLIENT_ID="ca-pub-xxxxxxxxxxxxxxxx"
NEXT_PUBLIC_ADSENSE_HOME_SLOT_ID=""
NEXT_PUBLIC_EXOCLICK_HOME_STICKY_ENABLED="true"
NEXT_PUBLIC_EXOCLICK_HOME_STICKY_ZONE_ID="5915396"
NEXT_PUBLIC_EXOCLICK_HOME_STICKY_CLASS="ea56a97888e17"
NEXT_PUBLIC_EXOCLICK_HOME_STICKY_LOCAL_DEBUG="true"
NEXT_PUBLIC_EXOCLICK_TOOL_INTERSTITIAL_ENABLED="true"
NEXT_PUBLIC_EXOCLICK_TOOL_INTERSTITIAL_ZONE_ID="5915410"
NEXT_PUBLIC_EXOCLICK_TOOL_INTERSTITIAL_CLASS="eas6a97888e35"
NEXT_PUBLIC_EXOCLICK_TOOL_INTERSTITIAL_SCRIPT_SRC="https://a.pemsrv.com/ad-provider.js"
NEXT_PUBLIC_ADBLOCK_NOTICE_ENABLED="true"
NEXT_PUBLIC_ADBLOCK_NOTICE_DISMISS_HOURS="24"
NEXT_PUBLIC_ADBLOCK_TEST_SCRIPT_SRC="https://a.magsrv.com/ad-provider.js"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"

# Target production database (Supabase / other managed Postgres)
# Runtime on Vercel/serverless: use the pooled connection string
POSTGRES_POOLED_URL="postgresql://...pooler...:6543/postgres?pgbouncer=true&connection_limit=1"
# Schema push / Prisma migrations on local IPv4 networks: use the Supavisor session pooler string (port 5432)
POSTGRES_SESSION_URL="postgresql://...pooler...:5432/postgres"
# Optional: only use the real direct database connection if your network supports IPv6 or you purchased the IPv4 add-on
POSTGRES_DIRECT_URL=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""

# Import source
CLEAN_IMAGE_ROOT="db image/clean"

# Optional Pixiv cookie for requests that need login/age-gated access
PIXIV_COOKIE=""
